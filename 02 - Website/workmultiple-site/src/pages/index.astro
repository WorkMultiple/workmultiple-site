---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import EmailCapture from '../components/EmailCapture.astro';
import { getCollection } from 'astro:content';

// Get blog posts for Latest Articles section
let posts: any[] = [];
try {
  const allPosts = await getCollection('blog');
  posts = allPosts
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 3);
} catch {
  // No blog posts yet, section will show empty state
}
---

<BaseLayout title="WorkMultiple | More done. Same team.">
  <div class="hero-bg-wrapper">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
  </div>

  <Header />

  <main>
    <!-- Hero -->
    <section class="hero animate-fade-up">
      <div class="container hero-inner">
        <div class="tagline badge">AI Automation</div>
        <h1 class="text-gradient">More done. <br/>Same team.</h1>
        <p class="hero-sub">Practical AI playbooks and guides for business owners who want results, not theory.</p>
        <div class="hero-actions">
          <a href="#subscribe" class="btn btn-primary">Get the free guides</a>
          <a href="/blog" class="btn btn-secondary">Read latest articles</a>
        </div>
      </div>
    </section>

    <!-- Credibility -->
    <section class="credibility">
      <div class="container">
        <div class="cred-grid">
          <div class="cred-card fade-in-up" style="animation-delay: 0.1s">
            <div class="cred-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </div>
            <h3>Tested, not theoretical.</h3>
            <p>We build and test every workflow before publishing it. No fluff.</p>
          </div>
          <div class="cred-card fade-in-up" style="animation-delay: 0.2s">
            <div class="cred-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 9.36l-6.9 6.9a2.12 2.12 0 0 1-3-3l6.9-6.9a6 6 0 0 1 9.36-7.94l-3.79 3.79z"></path></svg>
            </div>
            <h3>Implementation-ready.</h3>
            <p>Exact steps, exact tool settings, exact prompts. Follow along, get results.</p>
          </div>
          <div class="cred-card fade-in-up" style="animation-delay: 0.3s">
            <div class="cred-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </div>
            <h3>Built for non-technical people.</h3>
            <p>No coding required. No jargon. Just clear instructions that actually work.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Latest Articles -->
    <section class="latest-articles relative">
      <div class="container">
        <div class="section-header">
          <h2>Latest articles</h2>
          <a href="/blog" class="view-all">View all &rarr;</a>
        </div>
        {posts.length > 0 ? (
          <div class="articles-grid">
            {posts.map((post) => (
              <a href={`/blog/${post.slug}`} class="article-card">
                <time datetime={post.data.date}>{new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <div class="read-more">Read article &rarr;</div>
              </a>
            ))}
          </div>
        ) : (
          <div class="articles-empty glass-panel">
            <div class="empty-icon">📝</div>
            <p>First articles coming soon. Practical tool comparisons, workflow breakdowns, and AI guides built for business owners.</p>
            <a href="#subscribe" class="btn btn-accent empty-cta">Get notified when we publish</a>
          </div>
        )}
      </div>
    </section>

    <!-- Playbooks Coming Soon -->
    <section class="playbooks-teaser">
      <div class="area-glow"></div>
      <div class="container playbooks-inner glass-panel">
        <h2 class="text-gradient">Premium playbooks. Coming soon.</h2>
        <p>Step-by-step implementation guides that save you 20+ hours of trial and error. Each playbook covers one specific business problem, with exact tool settings, exact prompts, screenshots of every screen, and troubleshooting guides. Built for people who aren't developers.</p>
        <a href="#subscribe" class="btn btn-primary mt-4">Get notified at launch</a>
      </div>
    </section>

    <!-- Email Capture -->
    <section class="subscribe" id="subscribe">
      <div class="container subscribe-inner">
        <h2>Skip the 20 hours of trial and error.</h2>
        <p class="subscribe-sub">Get the exact AI workflows we test. Practical guides, tool reviews, and early access to new playbooks. No spam, no fluff.</p>
        <EmailCapture />
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Hero Background Effects */
  .hero-bg-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 80vh;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    width: 200%;
    height: 200%;
    top: -50%;
    left: -50%;
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    transform: perspective(500px) rotateX(60deg) translateY(-100px) translateZ(-200px);
    animation: gridMove 20s linear infinite;
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(0, 229, 255, 0.15) 0%, rgba(99, 102, 241, 0.05) 40%, transparent 70%);
    filter: blur(60px);
    animation: pulseGlow 8s ease-in-out infinite;
  }

  @keyframes gridMove {
    0% { transform: perspective(500px) rotateX(60deg) translateY(0) translateZ(-200px); }
    100% { transform: perspective(500px) rotateX(60deg) translateY(50px) translateZ(-200px); }
  }

  /* Typography Utilities */
  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    background: rgba(0, 229, 255, 0.1);
    border: 1px solid rgba(0, 229, 255, 0.2);
    border-radius: 9999px;
    margin-bottom: 1.5rem;
  }

  .mt-4 {
    margin-top: 1.5rem;
  }

  /* Hero Section */
  .hero {
    padding: 8rem 0 6rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero h1 {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: 1.5rem;
  }

  .hero-sub {
    font-size: clamp(1.125rem, 3vw, 1.375rem);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 3rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    align-items: center;
  }

  /* Credibility Section (Bento Style) */
  .credibility {
    padding: 2rem 0 6rem;
  }

  .cred-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .cred-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .cred-card::before {
    content: '';
    position: absolute;
    top: 0; right: 0; bottom: 0; left: 0;
    background: radial-gradient(800px circle at var(--mouse-x) var(--mouse-y), rgba(255,255,255,0.06), transparent 40%);
    z-index: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .cred-card:hover {
    border-color: rgba(255,255,255,0.1);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .cred-card:hover::before {
    opacity: 1;
  }

  .cred-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .cred-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
    position: relative;
    z-index: 1;
  }

  .cred-card p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    position: relative;
    z-index: 1;
  }

  /* Latest Articles */
  .latest-articles {
    padding: 6rem 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
  }

  .section-header h2 {
    font-size: 2.5rem;
    margin-bottom: 0;
  }

  .view-all {
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .view-all:hover {
    color: var(--color-text);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .article-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    background-color: var(--color-surface);
    transition: all 0.3s ease;
    height: 100%;
  }

  .article-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 10px 30px -10px rgba(0, 229, 255, 0.1);
    transform: translateY(-4px);
  }

  .article-card time {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .article-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .article-card p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    flex-grow: 1;
  }

  .read-more {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: auto;
  }

  .articles-empty {
    padding: 4rem 2rem;
    border-radius: 16px;
    text-align: center;
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.8;
  }

  .articles-empty p {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Playbooks Teaser */
  .playbooks-teaser {
    padding: 8rem 0;
  }

  .area-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, transparent 60%);
    filter: blur(40px);
    pointer-events: none;
  }

  .playbooks-inner {
    max-width: 720px;
    padding: 4rem;
    border-radius: 24px;
    text-align: center;
  }

  .playbooks-inner h2 {
    font-size: 2.5rem;
    margin-bottom: 1.25rem;
  }

  .playbooks-inner p {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  /* Subscribe Section */
  .subscribe {
    padding: 6rem 0 10rem;
    text-align: center;
  }

  .subscribe-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .subscribe h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .subscribe-sub {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: 3rem;
  }

  /* Fade in utilities */
  .fade-in-up {
    opacity: 0;
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: 5rem 0 4rem;
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
    }
    
    .hero-actions .btn {
      width: 100%;
    }

    .cred-grid, .articles-grid {
      grid-template-columns: 1fr;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .playbooks-inner {
      padding: 2.5rem 1.5rem;
    }

    .playbooks-inner h2, .section-header h2, .subscribe h2 {
      font-size: 2rem;
    }
  }
</style>

<script>
  // Simple hover effect for bento cards
  document.querySelectorAll('.cred-card').forEach(card => {
    card.addEventListener('mousemove', e => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      (card as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
      (card as HTMLElement).style.setProperty('--mouse-y', `${y}px`);
    });
  });
</script>
