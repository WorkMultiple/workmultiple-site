---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import EmailCapture from '../components/EmailCapture.astro';
import { getCollection } from 'astro:content';

// Get blog posts for Latest Articles section
let posts: any[] = [];
try {
  const allPosts = await getCollection('blog');
  const isDev = import.meta.env.DEV;
  posts = allPosts
    .filter((post) => isDev || post.data.status === 'published')
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 12);
} catch {
  // No blog posts yet, section will show empty state
}

const carouselPosts = posts.slice(0, 4);
const gridPosts = posts.slice(4);
---

<BaseLayout title="WorkMultiple | More done. Same team.">
  <div class="hero-bg-wrapper">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
  </div>

  <Header />

  <main>
    <!-- Featured Article Carousel -->
    {carouselPosts.length > 0 ? (
      <section class="carousel-section animate-fade-up">
        <div class="container">
          <div class="carousel" id="featured-carousel">
            <div class="carousel-track" id="carousel-track">
              {carouselPosts.map((post, i) => (
                <div class={`carousel-slide ${i === 0 ? 'active' : ''}`} data-index={i}>
                  <a href={`/blog/${post.id}`} class="carousel-card">
                    <div class="carousel-image-wrap">
                      <img
                        src={`/images/cards/${post.id}.png`}
                        alt={post.data.title}
                        class="carousel-image"
                      />
                    </div>
                    <div class="carousel-content">
                      <time datetime={post.data.date}>
                        {new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                      </time>
                      <h2>{post.data.title}</h2>
                      <p>{post.data.description}</p>
                      <span class="read-more">Read article &rarr;</span>
                    </div>
                  </a>
                </div>
              ))}
            </div>

            </div>

            <!-- Navigation arrows -->
            <button class="carousel-arrow carousel-arrow-prev" id="carousel-prev" aria-label="Previous slide">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button class="carousel-arrow carousel-arrow-next" id="carousel-next" aria-label="Next slide">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>

          <!-- Navigation dots -->
          <div class="carousel-dots" id="carousel-dots">
            {carouselPosts.map((_, i) => (
              <button
                class={`carousel-dot ${i === 0 ? 'active' : ''}`}
                data-index={i}
                aria-label={`Go to slide ${i + 1}`}
              />
            ))}
          </div>
        </div>
      </section>
    ) : (
      <section class="carousel-section animate-fade-up">
        <div class="container">
          <div class="articles-empty glass-panel fade-in-up">
            <div class="empty-icon">📝</div>
            <p>First articles coming soon. Practical tool comparisons, workflow breakdowns, and AI guides built for business owners.</p>
            <a href="#subscribe" class="btn btn-accent empty-cta mt-4">Get notified when we publish</a>
          </div>
        </div>
      </section>
    )}

    <!-- Article Grid -->
    {gridPosts.length > 0 && (
      <section class="article-grid-section">
        <div class="container">
          <h2 class="section-heading fade-in-up">All articles</h2>
          <div class="card-grid">
            {gridPosts.map((post, index) => (
              <a href={`/blog/${post.id}`} class="grid-card fade-in-up" style={`animation-delay: ${0.1 + (index * 0.05)}s`}>
                <div class="grid-card-image">
                  <img
                    src={`/images/cards/${post.id}.png`}
                    alt={post.data.title}
                    loading="lazy"
                  />
                </div>
                <div class="grid-card-body">
                  <time datetime={post.data.date}>
                    {new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                  </time>
                  <h3>{post.data.title}</h3>
                  <span class="read-more">Read article &rarr;</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Playbooks Coming Soon (Hidden) -->
    {false && (
    <section class="playbooks-teaser">
      <div class="area-glow"></div>
      <div class="container playbooks-inner glass-panel">
        <h2 class="text-gradient">Premium playbooks. Coming soon.</h2>
        <p>Step-by-step implementation guides that save you 20+ hours of trial and error. Each playbook covers one specific business problem, with exact tool settings, exact prompts, screenshots of every screen, and troubleshooting guides. Built for people who aren't developers.</p>
        <a href="#subscribe" class="btn btn-primary mt-4">Get notified at launch</a>
      </div>
    </section>
    )}

    <!-- Email Capture -->
    <section class="subscribe" id="subscribe">
      <div class="container subscribe-inner fade-in-up" style="animation-delay: 0.3s">
        <h2>Get our latest reviews and guides in your inbox.</h2>
        <p class="subscribe-sub">Get the exact AI workflows we test. Practical guides, tool reviews, and early access to new playbooks. No spam, no fluff.</p>
        <EmailCapture />
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ─── Hero Background Effects ─── */
  .hero-bg-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 80vh;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    width: 200%;
    height: 200%;
    top: -50%;
    left: -50%;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    transform: perspective(500px) rotateX(60deg) translateY(-100px) translateZ(-200px);
    animation: gridMove 20s linear infinite;
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(0, 229, 255, 0.15) 0%, rgba(99, 102, 241, 0.05) 40%, transparent 70%);
    filter: blur(60px);
    animation: pulseGlow 8s ease-in-out infinite;
  }

  @keyframes gridMove {
    0% { transform: perspective(500px) rotateX(60deg) translateY(0) translateZ(-200px); }
    100% { transform: perspective(500px) rotateX(60deg) translateY(50px) translateZ(-200px); }
  }

  /* ─── Utilities ─── */
  .mt-4 {
    margin-top: 2rem;
  }

  .fade-in-up {
    opacity: 0;
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* ─── Featured Carousel Section ─── */
  .carousel-section {
    padding: 6rem 0 2rem;
    position: relative;
  }

  .carousel {
    position: relative;
    overflow: hidden;
    border-radius: 20px;
  }

  .carousel-track {
    position: relative;
    min-height: 400px;
  }

  .carousel-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease, visibility 0.6s ease;
    z-index: 1;
  }

  .carousel-slide.active {
    opacity: 1;
    visibility: visible;
    position: relative;
    z-index: 2;
  }

  .carousel-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: var(--color-surface);
    border: 1px solid rgba(0, 229, 255, 0.2);
    border-radius: 20px;
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
    color: inherit;
  }

  .carousel-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 15px 50px -15px rgba(0, 229, 255, 0.2);
  }

  .carousel-image-wrap {
    position: relative;
    overflow: hidden;
    /* Removed aspect-ratio and height: 100% to let it stretch naturally on desktop */
    -webkit-mask-image: linear-gradient(to right, rgba(0,0,0,1) 85%, rgba(0,0,0,0) 100%);
    mask-image: linear-gradient(to right, rgba(0,0,0,1) 85%, rgba(0,0,0,0) 100%);
  }

  .carousel-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .carousel-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3rem;
  }

  .carousel-content time {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    display: block;
  }

  .carousel-content h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .carousel-content p {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    transition: transform 0.3s ease;
    display: inline-block;
  }

  .carousel-card:hover .read-more {
    transform: translateX(4px);
  }

  /* Carousel Navigation Dots */
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.5rem 0 0;
  }

  .carousel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .carousel-dot.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    box-shadow: 0 0 8px rgba(0, 229, 255, 0.4);
  }

  .carousel-dot:hover {
    border-color: var(--color-accent);
  }

  /* Carousel Arrows */
  .carousel-arrow {
    position: absolute;
    top: calc(50% - 1rem);
    transform: translateY(-50%);
    z-index: 10;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: rgba(18, 18, 20, 0.8);
    backdrop-filter: blur(8px);
    color: var(--color-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    padding: 0;
  }

  .carousel-arrow:hover {
    border-color: var(--color-accent);
    background: rgba(18, 18, 20, 0.95);
    box-shadow: 0 0 12px rgba(0, 229, 255, 0.2);
  }

  .carousel-arrow-prev {
    left: 1rem;
  }

  .carousel-arrow-next {
    right: 1rem;
  }

  /* ─── Section Heading (divider) ─── */
  .section-heading {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 2rem;
  }

  /* ─── Article Grid Section ─── */
  .article-grid-section {
    padding: 2rem 0 6rem;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .grid-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .grid-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 10px 30px -10px rgba(0, 229, 255, 0.15);
    transform: translateY(-4px);
  }

  .grid-card-image {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1200 / 630;
    background: var(--color-bg);
  }

  .grid-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .grid-card:hover .grid-card-image img {
    transform: scale(1.03);
  }

  .grid-card-body {
    display: flex;
    flex-direction: column;
    padding: 1.25rem 1.5rem 1.5rem;
    flex-grow: 1;
  }

  .grid-card-body time {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.625rem;
    display: block;
  }

  .grid-card-body h3 {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 1rem;
    color: var(--color-text);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .grid-card-body .read-more {
    margin-top: auto;
  }

  .grid-card:hover .read-more {
    transform: translateX(4px);
  }

  /* ─── Empty state ─── */
  .articles-empty {
    padding: 4rem 2rem;
    border-radius: 16px;
    text-align: center;
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.8;
  }

  .articles-empty p {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ─── Playbooks Teaser (Hidden) ─── */
  .playbooks-teaser {
    padding: 5rem 0;
  }

  .area-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, transparent 60%);
    filter: blur(40px);
    pointer-events: none;
  }

  .playbooks-inner {
    max-width: 720px;
    padding: 4rem;
    border-radius: 24px;
    text-align: center;
  }

  .playbooks-inner h2 {
    font-size: 2.5rem;
    margin-bottom: 1.25rem;
  }

  .playbooks-inner p {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  /* ─── Subscribe Section ─── */
  .subscribe {
    padding: 4rem 0 10rem;
    text-align: center;
  }

  .subscribe-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .subscribe h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .subscribe-sub {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: 3rem;
  }

  /* ─── Responsive: Tablet (1024px) ─── */
  @media (max-width: 1024px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ─── Responsive: Mobile (768px) ─── */
  @media (max-width: 768px) {
    .hero-bg-wrapper {
      height: 60vh;
    }

    .carousel-section {
      padding: 5rem 0 2rem;
    }

    .carousel-card {
      grid-template-columns: 1fr;
    }

    .carousel-image-wrap {
      aspect-ratio: 16 / 9;
    }

    .carousel-content {
      padding: 1.75rem;
    }

    .carousel-content h2 {
      font-size: 1.375rem;
    }

    .carousel-arrow {
      display: none;
    }

    .card-grid {
      grid-template-columns: 1fr;
    }

    .playbooks-inner {
      padding: 2.5rem 1.5rem;
    }

    .playbooks-inner h2, .subscribe h2 {
      font-size: 1.75rem;
    }
  }
</style>

<script>
  // Featured Carousel
  (function () {
    const slides = document.querySelectorAll('.carousel-slide');
    const dots = document.querySelectorAll('.carousel-dot');
    const prevBtn = document.getElementById('carousel-prev');
    const nextBtn = document.getElementById('carousel-next');

    if (!slides.length) return;

    let current = 0;
    const total = slides.length;
    let timer = null;
    const INTERVAL = 6000;

    function goTo(index) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = (index + total) % total;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
    }

    function next() {
      goTo(current + 1);
    }

    function prev() {
      goTo(current - 1);
    }

    function startTimer() {
      stopTimer();
      timer = setInterval(next, INTERVAL);
    }

    function stopTimer() {
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
    }

    // Dot click handlers
    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        var idx = parseInt(this.getAttribute('data-index'), 10);
        goTo(idx);
        startTimer();
      });
    });

    // Arrow click handlers
    if (prevBtn) {
      prevBtn.addEventListener('click', function () {
        prev();
        startTimer();
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function () {
        next();
        startTimer();
      });
    }

    // Pause when tab not visible
    document.addEventListener('visibilitychange', function () {
      if (document.hidden) {
        stopTimer();
      } else {
        startTimer();
      }
    });

    // Touch/swipe support for mobile
    var touchStartX = 0;
    var touchEndX = 0;
    var carousel = document.getElementById('featured-carousel');

    if (carousel) {
      carousel.addEventListener('touchstart', function (e) {
        touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });

      carousel.addEventListener('touchend', function (e) {
        touchEndX = e.changedTouches[0].screenX;
        var diff = touchStartX - touchEndX;
        if (Math.abs(diff) > 50) {
          if (diff > 0) {
            next();
          } else {
            prev();
          }
          startTimer();
        }
      }, { passive: true });
    }

    // Start auto-advance
    startTimer();
  })();
</script>
