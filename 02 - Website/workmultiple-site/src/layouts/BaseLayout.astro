---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  articleSchema?: {
    headline: string;
    description: string;
    datePublished: string;
    author: string;
  };
}

const {
  title,
  description = 'Practical AI playbooks and guides for business owners who want results, not theory.',
  ogImage = '/WorkMultiple_Logo_800x800.png',
  ogType = 'website',
  articleSchema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Analytics (GA4) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-N8EBSXFJLE"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-N8EBSXFJLE');
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@WorkMultipleAI" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <!-- Beehiiv attribution tracking -->
    <script is:inline type="text/javascript" async src="https://subscribe-forms.beehiiv.com/attribution.js"></script>

    {articleSchema && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": articleSchema.headline,
        "description": articleSchema.description,
        "datePublished": articleSchema.datePublished,
        "author": {
          "@type": "Person",
          "name": articleSchema.author,
        },
        "publisher": {
          "@type": "Organization",
          "name": "WorkMultiple",
          "url": "https://workmultiple.com",
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": canonicalURL.href,
        },
      })} />
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
