---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<BaseLayout title={`${post.data.title} | WorkMultiple`} description={post.data.description}>
  <Header />

  <article class="blog-post">
    <div class="container post-container">
      <header class="post-header">
        <time datetime={post.data.date}>{formattedDate}</time>
        <h1>{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>
      </header>

      <div class="post-content">
        <Content />
      </div>

      <div class="post-footer">
        <div class="post-cta">
          <h2>Skip the 20 hours of trial and error.</h2>
          <p>Get the exact AI workflows we test. Practical guides, tool reviews, and early access to new playbooks.</p>
          <EmailCapture />
        </div>
      </div>
    </div>
  </article>

  <Footer />
</BaseLayout>

<style>
  .blog-post {
    padding: 3rem 0 6rem;
  }

  .post-container {
    max-width: 720px;
  }

  .post-header {
    margin-bottom: 3rem;
  }

  .post-header time {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    display: block;
    margin-bottom: 0.75rem;
  }

  .post-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .post-description {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* Blog post content typography */
  .post-content {
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .post-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-content :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .post-content :global(code) {
    font-size: 0.9em;
    background-color: #f0f0f0;
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .post-content :global(pre) {
    background-color: #1a1a1a;
    color: #e5e5e5;
    padding: 1.25rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
  }

  .post-content :global(img) {
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  /* Post footer CTA */
  .post-footer {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
  }

  .post-cta {
    text-align: center;
  }

  .post-cta h2 {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .post-cta p {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }

  @media (max-width: 768px) {
    .post-header h1 {
      font-size: 2rem;
    }

    .post-content {
      font-size: 1rem;
    }
  }
</style>
