---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

let posts: any[] = [];
try {
  const allPosts = await getCollection('blog');
  posts = allPosts.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
} catch {
  // No posts yet
}
---

<BaseLayout
  title="Blog | WorkMultiple"
  description="Practical AI guides, tool comparisons, and workflow breakdowns. Tested, opinionated, and built for non-technical business owners."
>
  <Header />

  <section class="blog-listing">
    <div class="container">
      <h1>Blog</h1>
      <p class="blog-intro">Practical AI guides, tool comparisons, and workflow breakdowns. Everything is tested. Everything is opinionated.</p>

      {posts.length > 0 ? (
        <div class="posts-list">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="post-item">
              <time datetime={post.data.date}>{new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </a>
          ))}
        </div>
      ) : (
        <div class="posts-empty">
          <p>First articles are on the way. Practical tool comparisons, workflow breakdowns, and AI guides built for business owners.</p>
          <a href="/#subscribe" class="empty-cta">Get notified when we publish &rarr;</a>
        </div>
      )}
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .blog-listing {
    padding: 4rem 0 6rem;
  }

  .blog-listing h1 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .blog-intro {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: 3rem;
    max-width: 560px;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .post-item {
    display: block;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
    transition: opacity 0.2s ease;
  }

  .post-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-item:hover {
    opacity: 0.75;
  }

  .post-item time {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    display: block;
    margin-bottom: 0.375rem;
  }

  .post-item h2 {
    font-size: 1.375rem;
    font-weight: 600;
    margin-bottom: 0.375rem;
    line-height: 1.3;
  }

  .post-item p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    max-width: 600px;
  }

  .posts-empty {
    padding: 3rem;
    border: 1px dashed var(--color-border);
    border-radius: 8px;
    text-align: center;
  }

  .posts-empty p {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  .empty-cta {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-accent);
    transition: color 0.2s ease;
  }

  .empty-cta:hover {
    color: var(--color-accent-hover);
  }

  @media (max-width: 768px) {
    .blog-listing h1 {
      font-size: 2rem;
    }
  }
</style>
