---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const isDev = import.meta.env.DEV;
  return posts
    .filter((post) => isDev || post.data.status === 'published')
    .map((post) => ({
      params: { id: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<BaseLayout
  title={`${post.data.title} | WorkMultiple`}
  description={post.data.description}
  ogImage={`/images/cards/${post.id}.png`}
  ogType="article"
  articleSchema={{
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.date,
    author: post.data.author,
  }}
>
  <Header />

  <article class="blog-post">
    <div class="container post-container">
      <header class="post-header">
        <time datetime={post.data.date}>{formattedDate}</time>
        <h1>{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>
      </header>

      <div class="post-content">
        <Content />
      </div>

      <div class="post-share">
        <ShareButtons title={post.data.title} url={`https://workmultiple.com/blog/${post.id}`} />
      </div>

      <div class="post-footer">
        <div class="post-cta">
          <h2>Skip the 20 hours of trial and error.</h2>
          <p>Get the exact AI workflows we test. Practical guides, tool reviews, and early access to new playbooks.</p>
          <div class="beehiiv-wrapper">
            <script is:inline async src="https://subscribe-forms.beehiiv.com/embed.js"></script>
            <iframe
              src="https://subscribe-forms.beehiiv.com/20e51a6c-65f3-4d83-bea4-de245129feef"
              class="beehiiv-embed"
              data-test-id="beehiiv-embed"
              frameborder="0"
              scrolling="no"
              style="width: 100%; max-width: 560px; height: 315px; margin: 0; border-radius: 0; background-color: transparent; box-shadow: none;"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </article>

  <Footer />
</BaseLayout>

<style>
  .blog-post {
    padding: 3rem 0 6rem;
  }

  .post-container {
    max-width: 720px;
  }

  .post-header {
    margin-bottom: 3rem;
  }

  .post-header time {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    display: block;
    margin-bottom: 0.75rem;
  }

  .post-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .post-description {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* Blog post content typography */
  .post-content {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .post-content :global(h2) {
    font-size: 1.75rem;
    font-weight: 700;
    margin-top: 3.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .post-content :global(h3) {
    font-size: 1.375rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }

  .post-content :global(p) {
    margin-bottom: 1.5rem;
    color: var(--color-text-secondary);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--color-text-secondary);
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: rgba(0, 229, 255, 0.3);
    transition: all 0.2s ease;
  }

  .post-content :global(a:hover) {
    color: var(--color-accent-hover);
    text-decoration-color: var(--color-accent-hover);
  }

  .post-content :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    background: rgba(0, 229, 255, 0.03);
    padding: 1.5rem;
    margin: 2rem 0;
    border-radius: 0 8px 8px 0;
    color: var(--color-text);
    font-style: italic;
  }

  .post-content :global(code) {
    font-size: 0.875em;
    background-color: rgba(255,255,255,0.05);
    color: var(--color-text);
    padding: 0.2em 0.4em;
    border-radius: 6px;
    border: 1px solid rgba(255,255,255,0.05);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .post-content :global(pre) {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    color: #e5e5e5;
    padding: 1.5rem;
    border-radius: 12px;
    overflow-x: auto;
    margin: 2rem 0;
  }

  .post-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.875rem;
    color: inherit;
  }

  .post-content :global(img) {
    border-radius: 12px;
    margin: 2rem 0;
    border: 1px solid rgba(255,255,255,0.05);
    box-shadow: var(--shadow-md);
  }

  /* Comparison tables */
  .post-content :global(table) {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 2rem 0;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-md);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .post-content :global(thead) {
    background: linear-gradient(135deg, rgba(0, 229, 255, 0.08) 0%, rgba(99, 102, 241, 0.08) 100%);
  }

  .post-content :global(th) {
    padding: 0.875rem 1.25rem;
    text-align: left;
    font-weight: 600;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    white-space: nowrap;
  }

  .post-content :global(th:not(:last-child)),
  .post-content :global(td:not(:last-child)) {
    border-right: 1px solid var(--color-border);
  }

  .post-content :global(td) {
    padding: 0.75rem 1.25rem;
    color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }

  .post-content :global(tr:last-child td) {
    border-bottom: none;
  }

  .post-content :global(tbody tr) {
    background: var(--color-bg);
    transition: background 0.15s ease;
  }

  .post-content :global(tbody tr:hover) {
    background: var(--color-surface);
  }

  .post-content :global(td strong),
  .post-content :global(th strong) {
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .post-content :global(table) {
      font-size: 0.85rem;
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .post-content :global(th),
    .post-content :global(td) {
      padding: 0.625rem 0.875rem;
      min-width: 120px;
    }
  }

  /* Scrollable sources box */
  .post-content :global(.sources-scroll) {
    max-height: 320px;
    overflow-y: auto;
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
    scrollbar-width: thin;
    scrollbar-color: var(--color-border) transparent;
  }

  .post-content :global(.sources-scroll::-webkit-scrollbar) {
    width: 6px;
  }

  .post-content :global(.sources-scroll::-webkit-scrollbar-track) {
    background: transparent;
  }

  .post-content :global(.sources-scroll::-webkit-scrollbar-thumb) {
    background-color: var(--color-border);
    border-radius: 3px;
  }

  .post-content :global(.sources-scroll ol) {
    margin-bottom: 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .post-content :global(.sources-scroll li) {
    margin-bottom: 0.375rem;
  }

  /* Share buttons */
  .post-share {
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-border);
  }

  /* Post footer CTA */
  .post-footer {
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
  }

  .post-cta {
    text-align: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 24px;
    padding: 3rem 2rem;
    box-shadow: var(--shadow-lg);
  }

  .post-cta h2 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .post-cta p {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .beehiiv-wrapper {
    display: flex;
    justify-content: center;
    background: rgba(0,0,0,0.2);
    padding: 1rem;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.03);
  }

  @media (max-width: 768px) {
    .post-header h1 {
      font-size: 2rem;
    }

    .post-content {
      font-size: 1rem;
    }
  }
</style>

<script>
  // Open all external links in a new tab
  document.querySelectorAll('.post-content a').forEach(function (link) {
    var href = link.getAttribute('href');
    if (href && href.startsWith('http') && !href.includes('workmultiple.com')) {
      link.setAttribute('target', '_blank');
      link.setAttribute('rel', 'noopener noreferrer');
    }
  });
</script>
