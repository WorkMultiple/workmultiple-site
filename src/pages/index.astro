---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import EmailCapture from '../components/EmailCapture.astro';
import { getCollection } from 'astro:content';

// Get blog posts for Latest Articles section
let posts: any[] = [];
try {
  const allPosts = await getCollection('blog');
  const isDev = import.meta.env.DEV;
  posts = allPosts
    .filter((post) => isDev || post.data.status === 'published')
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 12);
} catch {
  // No blog posts yet, section will show empty state
}
---

<BaseLayout title="WorkMultiple | More done. Same team.">
  <div class="hero-bg-wrapper">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
  </div>

  <Header />

  <main>
    <!-- Hero (Masthead) -->
    <section class="hero animate-fade-up">
      <div class="container hero-inner">
        <div class="tagline badge">WorkMultiple</div>
        <h1 class="text-gradient">More done. <br/>Same team.</h1>
        <p class="hero-sub">Practical AI tool reviews, honest comparisons, and implementation-ready guides.</p>
      </div>
    </section>

    <!-- Content Feed -->
    <section class="latest-articles relative">
      <div class="container">
        {posts.length > 0 ? (
          <div class="articles-feed">
            {/* Featured Article */}
            <a href={`/blog/${posts[0].id}`} class="article-card featured-article fade-in-up" style="animation-delay: 0.1s">
              <div class="featured-indicator">Latest</div>
              <time datetime={posts[0].data.date}>{new Date(posts[0].data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
              <h3>{posts[0].data.title}</h3>
              <p>{posts[0].data.description}</p>
              <div class="read-more">Read article &rarr;</div>
            </a>
            
            {/* Grid for remaining articles */}
            {posts.length > 1 && (
              <div class="articles-grid mt-4">
                {posts.slice(1).map((post, index) => (
                  <a href={`/blog/${post.id}`} class="article-card fade-in-up" style={`animation-delay: ${0.2 + (index * 0.1)}s`}>
                    <time datetime={post.data.date}>{new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</time>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                    <div class="read-more">Read article &rarr;</div>
                  </a>
                ))}
              </div>
            )}
          </div>
        ) : (
          <div class="articles-empty glass-panel fade-in-up">
            <div class="empty-icon">📝</div>
            <p>First articles coming soon. Practical tool comparisons, workflow breakdowns, and AI guides built for business owners.</p>
            <a href="#subscribe" class="btn btn-accent empty-cta mt-4">Get notified when we publish</a>
          </div>
        )}
      </div>
    </section>

    <!-- Playbooks Coming Soon (Hidden) -->
    {false && (
    <section class="playbooks-teaser">
      <div class="area-glow"></div>
      <div class="container playbooks-inner glass-panel">
        <h2 class="text-gradient">Premium playbooks. Coming soon.</h2>
        <p>Step-by-step implementation guides that save you 20+ hours of trial and error. Each playbook covers one specific business problem, with exact tool settings, exact prompts, screenshots of every screen, and troubleshooting guides. Built for people who aren't developers.</p>
        <a href="#subscribe" class="btn btn-primary mt-4">Get notified at launch</a>
      </div>
    </section>
    )}

    <!-- Email Capture -->
    <section class="subscribe" id="subscribe">
      <div class="container subscribe-inner fade-in-up" style="animation-delay: 0.3s">
        <h2>Get our latest reviews and guides in your inbox.</h2>
        <p class="subscribe-sub">Get the exact AI workflows we test. Practical guides, tool reviews, and early access to new playbooks. No spam, no fluff.</p>
        <EmailCapture />
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Hero Background Effects */
  .hero-bg-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 60vh; /* Reduced height for tighter masthead */
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    width: 200%;
    height: 200%;
    top: -50%;
    left: -50%;
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    transform: perspective(500px) rotateX(60deg) translateY(-100px) translateZ(-200px);
    animation: gridMove 20s linear infinite;
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(0, 229, 255, 0.15) 0%, rgba(99, 102, 241, 0.05) 40%, transparent 70%);
    filter: blur(60px);
    animation: pulseGlow 8s ease-in-out infinite;
  }

  @keyframes gridMove {
    0% { transform: perspective(500px) rotateX(60deg) translateY(0) translateZ(-200px); }
    100% { transform: perspective(500px) rotateX(60deg) translateY(50px) translateZ(-200px); }
  }

  /* Typography Utilities */
  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    background: rgba(0, 229, 255, 0.1);
    border: 1px solid rgba(0, 229, 255, 0.2);
    border-radius: 9999px;
    margin-bottom: 1.5rem;
  }

  .mt-4 {
    margin-top: 2rem;
  }

  /* Hero Section (Masthead) */
  .hero {
    padding: 6rem 0 3rem; /* Tighter padding */
    text-align: center;
  }

  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero h1 {
    font-size: clamp(3rem, 8vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: 1.5rem;
  }

  .hero-sub {
    font-size: clamp(1.125rem, 3vw, 1.375rem);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Articles Feed */
  .latest-articles {
    padding: 2rem 0 6rem;
  }

  .articles-feed {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .article-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    background-color: var(--color-surface);
    transition: all 0.3s ease;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .article-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 10px 30px -10px rgba(0, 229, 255, 0.15);
    transform: translateY(-4px);
  }

  .featured-article {
    border-color: rgba(0, 229, 255, 0.3);
    background: linear-gradient(180deg, rgba(18, 18, 20, 0.8) 0%, rgba(18, 18, 20, 1) 100%);
    padding: 3rem;
  }

  .featured-article:hover {
    box-shadow: 0 15px 40px -10px rgba(0, 229, 255, 0.2);
  }

  .featured-indicator {
    position: absolute;
    top: 2rem;
    right: 2rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-bg);
    background: var(--color-accent);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
  }

  .article-card time {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .article-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .featured-article h3 {
    font-size: 2rem;
    margin-bottom: 1rem;
    max-width: 80%;
  }

  .article-card p {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    flex-grow: 1;
  }

  .featured-article p {
    font-size: 1.125rem;
    max-width: 75%;
  }

  .read-more {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-top: auto;
    transition: transform 0.3s ease;
  }

  .article-card:hover .read-more {
    transform: translateX(4px);
  }

  .articles-empty {
    padding: 4rem 2rem;
    border-radius: 16px;
    text-align: center;
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.8;
  }

  .articles-empty p {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Playbooks Teaser */
  .playbooks-teaser {
    padding: 5rem 0;
  }

  .area-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, transparent 60%);
    filter: blur(40px);
    pointer-events: none;
  }

  .playbooks-inner {
    max-width: 720px;
    padding: 4rem;
    border-radius: 24px;
    text-align: center;
  }

  .playbooks-inner h2 {
    font-size: 2.5rem;
    margin-bottom: 1.25rem;
  }

  .playbooks-inner p {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  /* Subscribe Section */
  .subscribe {
    padding: 4rem 0 10rem;
    text-align: center;
  }

  .subscribe-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .subscribe h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .subscribe-sub {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: 3rem;
  }

  /* Fade in utilities */
  .fade-in-up {
    opacity: 0;
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: 5rem 0 3rem;
    }
    
    .hero-bg-wrapper {
      height: 50vh;
    }

    .articles-grid {
      grid-template-columns: 1fr;
    }

    .featured-article {
      padding: 2rem;
    }

    .featured-article h3, .featured-article p {
      max-width: 100%;
    }
    
    .featured-indicator {
      top: 1.5rem;
      right: 1.5rem;
    }

    .playbooks-inner {
      padding: 2.5rem 1.5rem;
    }

    .playbooks-inner h2, .subscribe h2 {
      font-size: 1.75rem;
    }
  }
</style>
