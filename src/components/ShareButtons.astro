---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
---

<div class="share-buttons" data-title={title} data-url={url}>
  <span class="share-label">Share</span>

  <div class="share-icons">
    <!-- Twitter/X -->
    <a
      class="share-btn share-twitter"
      href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on X (Twitter)"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>

    <!-- LinkedIn -->
    <a
      class="share-btn share-linkedin"
      href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on LinkedIn"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>

    <!-- Reddit -->
    <a
      class="share-btn share-reddit"
      href={`https://www.reddit.com/submit?url=${encodeURIComponent(url)}&title=${encodeURIComponent(title)}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Share on Reddit"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
      </svg>
    </a>

    <!-- Email -->
    <a
      class="share-btn share-email"
      href={`mailto:?subject=${encodeURIComponent(title)}&body=${encodeURIComponent(`Check this out: ${url}`)}`}
      aria-label="Share via email"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
      </svg>
    </a>

    <!-- Native Share (mobile) -->
    <button
      class="share-btn share-native"
      aria-label="Share via device"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
        <polyline points="16 6 12 2 8 6"/>
        <line x1="12" y1="2" x2="12" y2="15"/>
      </svg>
    </button>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const container = document.querySelector('.share-buttons');
    if (!container) return;

    const title = container.getAttribute('data-title') || '';
    const url = container.getAttribute('data-url') || '';

    // Track all share button clicks
    const shareLinks = container.querySelectorAll('.share-btn');
    shareLinks.forEach((btn) => {
      btn.addEventListener('click', () => {
        const platforms: Record<string, string> = {
          'share-twitter': 'Twitter',
          'share-linkedin': 'LinkedIn',
          'share-reddit': 'Reddit',
          'share-email': 'Email',
          'share-native': 'Native Share',
        };
        const platform = Object.entries(platforms).find(([cls]) => btn.classList.contains(cls));
        if (platform && typeof amplitude !== 'undefined') {
          amplitude.track('Article Shared', {
            platform: platform[1],
            article_title: title,
            article_url: url,
          });
        }
      });
    });

    // Native share button
    const nativeBtn = container.querySelector('.share-native') as HTMLButtonElement;
    if (!nativeBtn) return;

    if (!navigator.share) {
      nativeBtn.style.display = 'none';
      return;
    }

    nativeBtn.addEventListener('click', async () => {
      try {
        await navigator.share({ title, url });
      } catch {
        // User cancelled or share failed silently
      }
    });
  });
</script>

<style>
  .share-buttons {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .share-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .share-icons {
    display: flex;
    gap: 0.5rem;
  }

  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    font: inherit;
    padding: 0;
  }

  .share-btn:hover {
    color: var(--color-text);
    border-color: rgba(255, 255, 255, 0.15);
    background: var(--color-surface-hover);
    transform: translateY(-1px);
  }

  .share-twitter:hover { color: #f8fafc; }
  .share-linkedin:hover { color: #0a66c2; }
  .share-reddit:hover { color: #ff4500; }
  .share-email:hover { color: var(--color-accent); }
  .share-native:hover { color: var(--color-accent); }
</style>
