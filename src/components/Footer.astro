---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-top">
      <a href="/" class="wordmark">WorkMultiple</a>
      <div class="footer-links">
        <a href="/privacy" class="footer-link">Privacy</a>
        <a href="/terms" class="footer-link">Terms</a>
        <a href="https://x.com/WorkMultipleAI" target="_blank" rel="noopener noreferrer" class="footer-link">X (Twitter)</a>
      </div>
    </div>
    <p class="copyright">&copy; {year} WorkMultiple. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    padding: 3rem 0 2rem;
    border-top: 1px solid var(--color-border);
    margin-top: 2rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .wordmark {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--color-text);
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  .footer-link:hover {
    color: var(--color-text);
  }

  .copyright {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .footer-top {
      flex-direction: column;
      gap: 1rem;
      align-items: flex-start;
    }
  }
</style>
